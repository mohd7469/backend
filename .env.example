# copy this file to .env and fill out the values

# Firebase service account. JSON stringified object. For example export
# FIREBASE_SERVICE_ACCOUNT="$(cat serviceAccountKey.json | jq -c .)"
FIREBASE_SERVICE_ACCOUNT={"type":"...","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# JWT keys and expirations
JWT_SECRET=your-jwt-secret-key-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server settings
PORT=5000
NODE_ENV=development

# CORS (allowed origin)
FRONTEND_URL=http://localhost:3000
